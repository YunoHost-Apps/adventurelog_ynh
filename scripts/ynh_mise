export MISE_VERSION=2026.3.15

readonly MISE_INSTALL_DIR="/opt/mise-global"
export MISE_INSTALL_DIR
export MISE_BIN_DIR="$MISE_INSTALL_DIR/mise/bin"

#export MISE_CONFIG_FILE="$install_dir/mise/mise.toml"
#export MISE_DATA_DIR="$install_dir/mise/"
#export MISE_CACHE_DIR="$install_dir/mise/cache"
#export MISE_STATE_DIR="$install_dir/mise/state"

export MISE_CONFIG_FILE="$MISE_INSTALL_DIR/apps/$app/mise.toml"
export MISE_DATA_DIR="$MISE_INSTALL_DIR/binaries/"
export MISE_CACHE_DIR="$MISE_INSTALL_DIR/cache"
export MISE_STATE_DIR="$MISE_INSTALL_DIR/state"

ynh_mise_install() {

    mkdir -p "${MISE_INSTALL_DIR}/mise"
    mkdir -p "${MISE_DATA_DIR}"

    if [[ ! -f "$MISE_BIN_DIR"/mise ]] || [[ "$($MISE_BIN_DIR/mise version --json | jq -r '.version' | awk '{print $1}')" != "$MISE_VERSION" ]]; then

        pushd "$MISE_INSTALL_DIR"/mise || ynh_die
        # Install the requested version of mise 
        if [[ $YNH_ARCH == "amd64" ]]; then
            wget --tries 3 --no-dns-cache --timeout 900 --no-verbose https://github.com/jdx/mise/releases/download/v$MISE_VERSION/mise-v$MISE_VERSION-linux-x64.tar.xz || ynh_die
            tar -xf mise-v$MISE_VERSION-linux-x64.tar.xz --strip-components 1
            rm mise-v$MISE_VERSION-linux-x64.tar.xz
        elif [[ $YNH_ARCH == "arm64" ]]; then
            wget --tries 3 --no-dns-cache --timeout 900 --no-verbose https://github.com/jdx/mise/releases/download/v$MISE_VERSION/mise-v$MISE_VERSION-linux-arm64.tar.xz || ynh_die
            tar -xf mise-v$MISE_VERSION-linux-arm64.tar.xz --strip-components 1
            rm mise-v$MISE_VERSION-linux-arm64.tar.xz
        elif [[ $YNH_ARCH == "armv7" ]]; then
            wget --tries 3 --no-dns-cache --timeout 900 --no-verbose https://github.com/jdx/mise/releases/download/v$MISE_VERSION/mise-v$MISE_VERSION-linux-armv7.tar.xz || ynh_die
            tar -xf mise-v$MISE_VERSION-linux-armv7.tar.xz --strip-components 1
            rm mise-v$MISE_VERSION-linux-armv7.tar.xz
        else
            echo "No available mise version for this architecture. Please raise an issue so we can have a look."
        fi
        popd || ynh_die
    fi
}