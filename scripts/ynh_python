_ynh_load_python_in_path_and_other_tweaks() {

    # Get the absolute path of this version of Python
    python_dir=$(MISE_DATA_DIR="$MISE_DATA_DIR" MISE_CACHE_DIR="$MISE_CACHE_DIR" MISE_STATE_DIR="$MISE_STATE_DIR" "$MISE_BIN_DIR/mise" bin-paths "python@$python_version")

    if [ ! -e "$python_dir" ]; then
        echo "Skipping loading python, because it doesn't seem to be provisioned yet. This is likely to happen during restore and other specific contexts."
        return
    fi

    # Load the path of this version of uv in $PATH
    # DO NOT load the path of the python version, as it will break the use of other helpers
    if [[ -v uv_version ]]; then
        uv_dir=$(MISE_DATA_DIR="$MISE_DATA_DIR" MISE_CACHE_DIR="$MISE_CACHE_DIR" MISE_STATE_DIR="$MISE_STATE_DIR" "$MISE_BIN_DIR/mise" bin-paths "uv@$uv_version")
        if [[ :$PATH: != *":$uv_dir"* ]]; then
            PATH="$uv_dir:$PATH"
        fi
        # Export PATH such that it's available through sudo -E / ynh_exec_as_app
        export PATH

        # This is in full lowercase such that it gets replaced in templates
        # shellcheck disable=SC2034
        path_with_uv="$PATH"
        # shellcheck disable=SC2034
        PATH_with_uv="$PATH"
    fi

}

# Auto-load Python path tweaks if this app uses the python resource in the manifest
if [ -n "${python_version:-}" ] && (cat "$YNH_APP_BASEDIR/manifest.toml" | toml_to_json | jq -e ".resources.python" > /dev/null); then
    _ynh_load_python_in_path_and_other_tweaks
fi

# Install a specific version of Python using mise
#
# The installed version is defined by `$python_version` which should be defined as global prior to calling this helper
#
# usage: ynh_python_install
#
# The helper adds the appropriate, specific version of python to the `$PATH` variable (which
# is preserved when calling ynh_exec_as_app). Also defines:
#
# - `$path_with_python` to be used in the systemd config (`Environment="PATH=__PATH_WITH_PYTHON__"`)
# - `$python_dir`, the directory containing the specific version of python, which may be used in the systemd config too (e.g. `ExecStart=__PYTHON_DIR__/python foo bar`)
ynh_python_install() {

    [[ -n "${python_version:-}" ]] || ynh_die "\$python_version should be defined prior to calling ynh_python_install"

    # Install the requested version of Python
    local final_python_version=$("${MISE_BIN_DIR}"/mise ls-remote python@"$python_version" --json | jq -r '.[].version' | tail -n1 )
    python_version=${final_python_version:-$python_version}
    ynh_app_setting_set --key=python_version --value="$python_version"

    # If uv_version exist, then check it and install it too
    if [[ -n "${uv_version:-}" ]]; then
    # Install the requested version of Python
    local final_uv_version=$("${MISE_BIN_DIR}"/mise ls-remote uv@"$uv_version" --json | jq -r '.[].version' | tail -n1 )
    uv_version=${final_uv_version:-$uv_version}
    ynh_app_setting_set --key=uv_version --value="$uv_version"
    fi

    ynh_mise_install

    # Installing precompiled python from the $install_dir so the created mise.toml will be at the right place
    pushd "$install_dir" || ynh_die
        ynh_hide_warnings env MISE_DATA_DIR="$MISE_DATA_DIR" MISE_CACHE_DIR="$MISE_CACHE_DIR" MISE_STATE_DIR="$MISE_STATE_DIR" "$MISE_BIN_DIR"/mise use python@"$python_version"
        if [[ -v uv_version ]]; then
            ynh_hide_warnings env MISE_DATA_DIR="$MISE_DATA_DIR" MISE_CACHE_DIR="$MISE_CACHE_DIR" MISE_STATE_DIR="$MISE_STATE_DIR" "$MISE_BIN_DIR"/mise use uv@"$uv_version"
        fi
    popd || ynh_die

    _ynh_load_python_in_path_and_other_tweaks
}

# Remove the version of Python used by the app.
#
# This helper will also cleanup unused Python versions
#
# usage: ynh_python_remove
ynh_python_remove() {

    [[ -n "${python_version:-}" ]] || ynh_die "\$python_version should be defined prior to calling ynh_python_remove"

    # Remove the line for this app
    ynh_app_setting_delete --key="python_version"

    # Remove no more needed versions of Python used by the app.
    # This helper will check what Python version are no more required,
    # and uninstall them
    local installed_python_versions=$(MISE_DATA_DIR="$MISE_DATA_DIR" MISE_CACHE_DIR="$MISE_CACHE_DIR" MISE_STATE_DIR="$MISE_STATE_DIR" "${MISE_BIN_DIR}/mise" ls python --json | jq -r '.[].version')
    for installed_python_version in $installed_python_versions; do
        if [[ -n "$installed_python_version" ]] && ! grep -qE "^python_version: '?$installed_python_version'?" /etc/yunohost/apps/*/settings.yml; then
            ynh_print_info "Removing python@$installed_python_version"
            ynh_hide_warnings "$MISE_BIN_DIR/mise" unuse python@"$installed_python_version"
            ynh_hide_warnings "$MISE_BIN_DIR/mise" prune python@"$installed_python_version"
        fi
    done

    # Same for uv
    local installed_uv_versions=$(MISE_DATA_DIR="$MISE_DATA_DIR" MISE_CACHE_DIR="$MISE_CACHE_DIR" MISE_STATE_DIR="$MISE_STATE_DIR" "${MISE_BIN_DIR}/mise" ls uv --json | jq -r '.[].version')
    for installed_uv_version in $installed_uv_versions; do
        if [[ -n "$installed_uv_version" ]] && ! grep -qE "^python_version: '?$installed_uv_version'?" /etc/yunohost/apps/*/settings.yml; then
            ynh_print_info "Removing uv@$installed_python_version"
            ynh_hide_warnings "$MISE_BIN_DIR/mise" unuse uv@"$installed_uv_version"
            ynh_hide_warnings "$MISE_BIN_DIR/mise" prune uv@"$installed_uv_version"
        fi
    done
}